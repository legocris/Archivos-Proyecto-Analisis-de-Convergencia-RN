                return 1;
            }
        }
        // ------------------ 3. Iteraciones (int) ------------------
        else if (strcmp(arg, "-i") == 0 || strcmp(arg, "--Iteraciones") == 0) {
            if (i + 1 < argc) {
                Iteraciones = atoi(argv[++i]);
            } else {
                fprintf(stderr, "Error: El flag %s requiere un valor.\n", arg);
                return 1;
            }
        }
        // ------------------ 4. CapasDesde (int) ------------------
        else if (strcmp(arg, "-cd") == 0 || strcmp(arg, "--CapasDesde") == 0) {
