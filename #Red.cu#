            }
        }
        // ------------------ 5. CapasHasta (int) ------------------
        else if (strcmp(arg, "-ch") == 0 || strcmp(arg, "--CapasHasta") == 0) {
            if (i + 1 < argc) {
                CapasHasta = atoi(argv[++i]);
            } else {
